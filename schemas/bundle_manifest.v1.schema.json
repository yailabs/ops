{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai://schemas/bundle_manifest.v1.schema.json",
  "title": "bundle_manifest.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "bundle", "pins", "hashes", "artifacts"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "v1",
      "description": "Schema version for this manifest format."
    },

    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["wave", "bundle"],
          "description": "Bundle kind. Use 'wave' for evidence release waves."
        },
        "id": {
          "type": "string",
          "minLength": 6,
          "description": "Canonical bundle identifier (e.g., WAVE-1-YYYY-MM-DD-<shortsha>)."
        },
        "alias": {
          "type": "string",
          "minLength": 1,
          "description": "Human-friendly alias (e.g., SC102-WAVE1-LAUNCH)."
        },
        "series": {
          "type": "string",
          "minLength": 1,
          "description": "Optional series name (e.g., SC102-WAVE1)."
        },
        "scenario_id": {
          "type": "string",
          "minLength": 1,
          "description": "Optional scenario identifier (e.g., SC102)."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Bundle creation timestamp (ISO 8601)."
        },
        "created_by": {
          "type": "string",
          "minLength": 1,
          "description": "Producer identifier (human or system)."
        },
        "notes": {
          "type": "string",
          "description": "Optional freeform notes for auditors/reviewers."
        }
      }
    },

    "pins": {
      "type": "object",
      "additionalProperties": false,
      "required": ["yai", "yai_cli", "yai_law_or_specs"],
      "properties": {
        "yai": { "$ref": "#/$defs/pin" },
        "yai_cli": { "$ref": "#/$defs/pin" },
        "yai_law_or_specs": { "$ref": "#/$defs/pin" },
        "infra": { "$ref": "#/$defs/pin" },
        "ops": { "$ref": "#/$defs/pin" }
      },
      "description": "Pinned source baselines used to produce this bundle."
    },

    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index_sha256"],
      "properties": {
        "index_sha256": { "$ref": "#/$defs/sha256" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "verify_outputs_sha256": { "$ref": "#/$defs/sha256" },
        "manifest_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "Optional: sha256 of MANIFEST.json recorded externally or after generation."
        }
      },
      "description": "Hashes for key top-level artifacts. 'policy_sha256' and 'verify_outputs_sha256' are optional if not applicable."
    },

    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" },
      "description": "Inventory of files included in the bundle with integrity hashes."
    },

    "runs": {
      "type": "array",
      "items": { "$ref": "#/$defs/run_ref" },
      "description": "Optional references to executed runs that produced this bundle."
    },

    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "procedure_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to verification procedure (e.g., verify.sh)."
        },
        "executed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of verification execution."
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "unknown"],
          "description": "Verification outcome."
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_ref" },
          "description": "References to verification output artifacts (e.g., verify/*.txt)."
        }
      },
      "description": "Optional verification metadata for the bundle."
    },

    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Extension area for experimental or domain-specific fields without breaking the core schema."
    }
  },

  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "SHA-256 hex digest (64 chars)."
    },

    "pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "sha"],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1,
          "description": "Repository identifier (e.g., yai-labs/yai)."
        },
        "sha": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{7,40}$",
          "description": "Pinned commit SHA (short or full)."
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Optional ref name (tag/branch) used when producing the bundle; SHA remains authoritative."
        }
      }
    },

    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Path relative to bundle root."
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "kind": {
          "type": "string",
          "enum": ["manifest", "index", "policy", "run", "verify", "report", "asset", "other"],
          "description": "Artifact classification for audit/navigation."
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "description": "Optional media type (e.g., application/json, text/markdown)."
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional artifact size in bytes."
        }
      }
    },

    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },

    "run_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "path"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1,
          "description": "Run identifier (repo-specific)."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to run directory relative to repo root."
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "deny", "unknown"],
          "description": "Optional run outcome classification."
        },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}